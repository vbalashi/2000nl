# Public (inlined into Next.js client bundle)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Automated testing (Playwright, browser automation)
# Keep real credentials in `.env.local` (gitignored); never commit them.
TEST_USER_EMAIL=test@2000nl.test
TEST_USER_PASSWORD=test-password-123

# Optional: enables provisioning/seeding via Supabase Admin API scripts (server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Dedicated read-only token for external public catalog lookup/search.
# External clients send this to /api/platform/v1/catalog/lookup and
# /api/platform/v1/catalog/search. Do not reuse a shared end-user token here.
PLATFORM_CATALOG_ACCESS_TOKEN=your-random-catalog-token
